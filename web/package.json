{
  "name": "auto-pr-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "openapi:lint": "redocly lint ../openapi/openapi.yaml --config ../redocly.yaml",
    "openapi:bundle": "redocly bundle ../openapi/openapi.yaml --config ../redocly.yaml -o ../openapi/openapi.bundle.yaml",
    "openapi:generate": "npm run openapi:bundle && openapi-typescript ../openapi/openapi.bundle.yaml -o src/generated/api.ts"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@redocly/cli": "^2.30.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.20.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^26.0.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.24.0",
    "vite": "^8.0.10",
    "vitest": "^3.2.0"
  }
}
